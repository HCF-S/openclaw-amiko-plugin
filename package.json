{
  "name": "@heyamiko/openclaw-amiko",
  "version": "0.3.2",
  "description": "OpenClaw channel plugin for connecting agents to the Amiko platform via webhook.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills",
    "contracts",
    "openclaw.plugin.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist .tmp",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --test src/**/*.test.ts"
  },
  "keywords": [
    "openclaw",
    "amiko",
    "plugin",
    "channel",
    "webhook"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HCF-S/openclaw-amiko-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/HCF-S/openclaw-amiko-plugin/issues"
  },
  "homepage": "https://github.com/HCF-S/openclaw-amiko-plugin#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "openclaw": "2026.3.13"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "openclaw": "2026.3.13",
    "typescript": "^5.3.0"
  },
  "openclaw": {
    "id": "openclaw-amiko",
    "extensions": ["./dist/index.js"],
    "channel": {
      "id": "amiko",
      "label": "Amiko",
      "selectionLabel": "Amiko (Webhook)",
      "blurb": "Connect OpenClaw to Amiko platform (direct and group chat)"
    },
    "install": {
      "npmSpec": "@heyamiko/openclaw-amiko",
      "localPath": "."
    }
  }
}
