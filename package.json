{
  "name": "openclaw-amiko-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test:m0": "rm -rf .tmp/m0 && tsc -p tsconfig.m0.json && node --test .tmp/m0/*.test.js",
    "test": "node --test src/**/*.test.ts"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.4"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "channel": {
      "id": "amiko",
      "label": "Amiko",
      "selectionLabel": "Amiko (Webhook)",
      "blurb": "Connect OpenClaw to Amiko platform (direct and group chat)"
    },
    "install": {
      "npmSpec": "openclaw-amiko-plugin",
      "localPath": "."
    }
  }
}
