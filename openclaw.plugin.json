{
  "id": "openclaw-amiko",
  "name": "Amiko",
  "description": "OpenClaw channel plugin for Amiko platform — direct and group chat via webhook.",
  "version": "0.3.7-beta.0",
  "channels": ["amiko"],
  "skills": ["./skills"],
  "hooks": ["./hooks"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "uiHints": {
    "token": {
      "label": "API Token",
      "sensitive": true,
      "placeholder": "amk_live_..."
    },
    "twinId": {
      "label": "Twin ID",
      "placeholder": "cmmkxz9qh0005r7489lrqt4kg"
    },
    "platformApiBaseUrl": {
      "label": "Platform API Base URL",
      "placeholder": "https://platform.heyamiko.com"
    },
    "chatApiBaseUrl": {
      "label": "Chat API Base URL",
      "placeholder": "https://api.amiko.app"
    },
    "apiBaseUrl": {
      "label": "Legacy API Base URL",
      "placeholder": "https://platform.heyamiko.com"
    },
    "name": {
      "label": "Account Name",
      "placeholder": "Production Account"
    },
    "enabled": {
      "label": "Enabled"
    },
    "pollIntervalMs": {
      "label": "Poll Interval (ms)",
      "placeholder": "3000"
    },
    "pollTimeoutMs": {
      "label": "Poll Timeout (ms)",
      "placeholder": "10000"
    }
  }
}
